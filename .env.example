POSTGRES_DB=mentoring
POSTGRES_USER=mentoring
POSTGRES_PASSWORD=mentoring
POSTGRES_HOST=db
POSTGRES_PORT=5432

DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,web
SITE_URL=http://127.0.0.1:8000

# Почта (для подтверждения email при регистрации)
# Без этих строк письма только в логах Docker: docker compose logs web
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.yandex.ru
EMAIL_PORT=587
EMAIL_HOST_USER=your-login@yandex.ru
EMAIL_HOST_PASSWORD=your-yandex-app-password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=your-login@yandex.ru
